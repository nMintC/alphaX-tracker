# ── X/Twitter Burner Account ──────────────────────────
# Use a burner account! Don't use your main account.
X_USERNAME=your_burner_username
X_EMAIL=your_burner_email@example.com
X_PASSWORD=your_burner_password

# ── Discord Bot ──────────────────────────────────────
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_channel_id_for_alerts

# ── Settings (optional, defaults are fine) ────────────
# POLL_INTERVAL_SECONDS=120
# REQUEST_DELAY_MIN=5
# REQUEST_DELAY_MAX=15
